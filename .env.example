# Backend (NestJS). Local QA: http://localhost:3002 · Producción: dominio de Railway.
# Producción real:
#   https://negoinversiones-back-production.up.railway.app

# Usada por el cliente (browser) para llamadas directas con Bearer (getMe, módulos).
NEXT_PUBLIC_API_BASE_URL=https://negoinversiones-back-production.up.railway.app

# Usada por el BFF (route handlers server-side: login/refresh/logout).
# Si no se define, cae a NEXT_PUBLIC_API_BASE_URL.
API_BASE_URL=https://negoinversiones-back-production.up.railway.app
